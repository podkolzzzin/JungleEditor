{
  "name": "jungle-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A full-featured browser-based video editor built with Vue 3, WebCodecs, WebGPU, and modern Web APIs",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.7.0",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.24.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.1",
    "vue-tsc": "^2.2.8"
  }
}
